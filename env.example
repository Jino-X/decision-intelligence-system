# =============================================
# AI Life OS - Environment Variables Example
# =============================================
# Copy this file to .env.local and fill in values

# ----- NextAuth -----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# ----- Google OAuth (NextAuth provider) -----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-api-key

# ----- Firebase (Client SDK - public) -----
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ----- Firebase Admin SDK (Server-side - PRIVATE) -----
# Option 1: Service Account JSON (recommended for production)
# Download from Firebase Console > Project Settings > Service Accounts
# Stringify the JSON and paste it here (keep it secret!)
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Option 2: Use Application Default Credentials (for local dev with gcloud auth)
# If FIREBASE_SERVICE_ACCOUNT_KEY is not set, the app will use the project ID only
# This works if you're authenticated with `gcloud auth application-default login`
